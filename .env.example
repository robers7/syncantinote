# Server
SYNCANTINOTE_SERVER_PORT=3177
SYNCANTINOTE_SERVER_HOST=127.0.0.1
SYNCANTINOTE_SERVER_DB_PATH=/var/lib/syncantinote/server.sqlite3
SYNCANTINOTE_TOKEN_SALT=change-me
# Optional: when set, /auth/device requires this exact header value in
# x-syncantinote-enrollment-key
SYNCANTINOTE_ENROLLMENT_KEY=

# Helper
SYNCANTINOTE_DEVICE_ID=macbook-pro
SYNCANTINOTE_DEVICE_NAME=MacBook Pro
SYNCANTINOTE_API_BASE_URL=https://feisio.com/feisiomark/api
SYNCANTINOTE_API_TOKEN=
SYNCANTINOTE_ANTINOTE_DB_PATH=$HOME/Library/Containers/com.chabomakers.Antinote/Data/Library/Application Support/Antinote/notes.sqlite3
SYNCANTINOTE_HELPER_DB_PATH=$HOME/Library/Containers/com.chabomakers.Antinote/Data/Library/Application Support/AntinoteSync/sync_state.sqlite3
SYNCANTINOTE_POLL_INTERVAL_MS=30000
